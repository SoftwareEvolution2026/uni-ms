# PostgreSQL is the official database. Copy this file to .env and keep it untracked.
SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:postgresql://localhost:5432/uni_ms
DB_USER=uni_ms
DB_PASSWORD=uni_ms

# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_ISSUER=uni-ms
JWT_AUDIENCE=uni-ms-api
JWT_CLOCK_SKEW_SECONDS=30

LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW=15m

# Initial administrator creation is opt-in. Never use the example password in production.
INITIAL_ADMIN_ENABLED=false
INITIAL_ADMIN_NAME=Academic Administrator
INITIAL_ADMIN_EMAIL=admin@university.test
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

CORS_ORIGINS=http://localhost:5173
PORT=8081
