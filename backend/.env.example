# Copy to .env (git-ignored). Spring reads these as environment variables.
#
# --- Default: MySQL (most of the team) ---
# createDatabaseIfNotExist=true lets the driver create the uni_ms schema automatically.
DB_URL=jdbc:mysql://localhost:3306/uni_ms?createDatabaseIfNotExist=true&allowPublicKeyRetrieval=true
DB_USER=root
DB_PASSWORD=root

# --- Alternative: MariaDB ---
# Instead of the DB_URL above, run with the 'mariadb' profile and this URL:
#   SPRING_PROFILES_ACTIVE=mariadb   (or  mvn spring-boot:run -Dspring-boot.run.profiles=mariadb)
# DB_URL=jdbc:mariadb://localhost:3306/uni_ms?createDatabaseIfNotExist=true

# Generate your own with: openssl rand -base64 48  (do NOT commit a real secret)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Token lifetimes
JWT_ACCESS_EXPIRATION_MS=900000       # 15 minutes
JWT_REFRESH_EXPIRATION_MS=604800000   # 7 days
